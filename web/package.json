{
  "name": "@availability/web",
  "version": "1.0.0",
  "description": "Availability polling frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "openapi-typescript ../api/openapi.yaml -o src/shared/api/generated/schema.d.ts",
    "dev": "vite",
    "build": "pnpm run generate && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.26.0",
  "dependencies": {
    "@internationalized/date": "3.12.2",
    "@tanstack/react-query": "5.101.1",
    "@tanstack/react-router": "1.170.16",
    "openapi-fetch": "0.17.0",
    "react": "19.2.7",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.7",
    "react-intl": "10.1.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "openapi-typescript": "^7.13.0",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  }
}
